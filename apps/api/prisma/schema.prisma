generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  EDITOR
  VIEWER
}

enum AssetType {
  VIDEO
  IMAGE
  VOICE
  MUSIC
  AVATAR
  SCRIPT
}

enum ProjectStatus {
  DRAFT
  SCRIPT_READY
  RENDERING
  COMPLETED
  FAILED
}

enum JobStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum ProviderType {
  SCRIPT
  MEDIA
  VOICE
  MUSIC
  AVATAR
  VIDEO
  MERGE
  STORAGE
  DISTRIBUTION
}

model Tenant {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  brandColor  String   @default("#6d5dfc")
  monthlyLimit Int     @default(100)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       User[]
  projects    Project[]
  assets      Asset[]
  providers   ProviderCredential[]
  auditLogs   AuditLog[]
}

model User {
  id           String   @id @default(cuid())
  tenantId     String
  email        String   @unique
  name         String
  passwordHash String
  role         Role     @default(EDITOR)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  auditLogs    AuditLog[]
}

model Project {
  id             String        @id @default(cuid())
  tenantId       String
  title          String
  mode           String
  sourceText     String
  targetAudience String?
  style          String?
  duration       Int           @default(30)
  aspectRatio    String        @default("9:16")
  status         ProjectStatus @default(DRAFT)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  tenant         Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  scenes         Scene[]
  renderJobs     RenderJob[]
}

model Scene {
  id             String   @id @default(cuid())
  projectId      String
  order          Int
  title          String
  narration      String
  visualPrompt   String
  durationSeconds Int
  assetId        String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  asset          Asset?   @relation(fields: [assetId], references: [id], onDelete: SetNull)
}

model Asset {
  id          String    @id @default(cuid())
  tenantId    String
  type        AssetType
  name        String
  url         String
  mimeType    String?
  tags        String[]  @default([])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  scenes      Scene[]
}

model RenderJob {
  id          String    @id @default(cuid())
  tenantId    String
  projectId   String
  status      JobStatus @default(QUEUED)
  stage       String    @default("render")
  progress    Int       @default(0)
  outputUrl   String?
  error       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
}

model ProviderCredential {
  id             String       @id @default(cuid())
  tenantId       String
  type           ProviderType
  provider       String
  displayName    String
  encryptedKey   String?
  priority       Int          @default(1)
  enabled        Boolean      @default(true)
  config         Json         @default("{}")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  tenant         Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, type, enabled])
}

model AuditLog {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String?
  action    String
  entity    String
  entityId  String?
  metadata  Json     @default("{}")
  createdAt DateTime @default(now())

  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}
